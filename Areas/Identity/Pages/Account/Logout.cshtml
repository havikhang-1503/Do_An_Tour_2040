@page
@model LogoutModel

@{
    ViewData["Title"] = "Đăng xuất";
}

@*
  Folder: Areas/Identity/Pages/Account
  File path: Areas/Identity/Pages/Account/Logout.cshtml
  File name: Logout.cshtml
  Labels: A(Glass UI), B(Pill buttons), C(Danger confirm)
  Notes:
    - Đồng bộ style nhẹ như Login/Index/Voucher
*@

<style>
    :root {
        --bg: #F6F8FF;
        --text: #0f172a;
        --muted: #64748b;
        --border: 1px solid rgba(226,232,240,.92);
        --shadow: 0 22px 56px rgba(2,6,23,.14);
        --outer-gutter: clamp(14px, 3vw, 56px);
    }

    body {
        background: var(--bg) !important;
        color: var(--text);
        font-family: Inter,system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    }

    .auth-bg {
        min-height: 72vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 22px var(--outer-gutter);
        position: relative;
        overflow: hidden;
    }

        .auth-bg::before {
            content: "";
            position: absolute;
            inset: -120px;
            background: radial-gradient(760px 360px at 18% 15%, rgba(37,99,235,.10), transparent 60%), radial-gradient(680px 360px at 82% 25%, rgba(245,158,11,.10), transparent 62%), radial-gradient(860px 520px at 50% 92%, rgba(34,197,94,.08), transparent 62%);
            pointer-events: none;
        }

    .card-glass {
        width: min(720px, 100%);
        background: rgba(255,255,255,.88);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: var(--border);
        border-radius: 28px;
        box-shadow: var(--shadow);
        padding: 2.2rem 2rem;
    }

    .icon-hero {
        width: 64px;
        height: 64px;
        border-radius: 20px;
        display: grid;
        place-items: center;
        margin: 0 auto 14px;
        border: var(--border);
        background: rgba(248,250,252,.92);
        box-shadow: 0 16px 26px rgba(2,6,23,.10);
    }

    .btn-pill {
        border-radius: 999px !important;
        font-weight: 950;
        box-shadow: 0 18px 34px rgba(2,6,23,.10);
        white-space: nowrap;
    }
</style>

<div class="auth-bg">
    <div class="card-glass text-center">
        <div class="icon-hero">
            <i class="bi bi-box-arrow-right fs-3 text-danger"></i>
        </div>

        <h1 class="fw-bold mb-2">@ViewData["Title"]</h1>

        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <p class="text-muted fw-bold mb-4">
                Bạn có chắc chắn muốn đăng xuất khỏi <strong>Tour_2040</strong>?
            </p>

            <form class="d-inline"
                  asp-area="Identity"
                  asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Page("/", new { area = "" })"
                  method="post">
                <button type="submit" class="btn btn-danger btn-pill px-4 py-2">
                    Đăng xuất
                </button>
            </form>

            <div class="mt-3 small text-muted fw-bold">
                Mất công đăng nhập lại đó, nên nghĩ kỹ. (Đùa thôi, bấm đi 😌)
            </div>
        }
        else
        {
            <p class="text-muted fw-bold mb-4">
                Bạn đã đăng xuất khỏi hệ thống.
            </p>

            <a asp-area="" asp-controller="Home" asp-action="Index"
               class="btn btn-primary btn-pill px-4 py-2">
                Quay về trang chủ
            </a>
        }
    </div>
</div>
