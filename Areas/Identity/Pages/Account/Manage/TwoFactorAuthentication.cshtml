@page
@model Tour_2040.Areas.Identity.Pages.Account.Manage.TwoFactorAuthenticationModel
@{
    ViewData["Title"] = "Bảo mật 2 lớp (2FA)";
}

@* --- CSS TÙY CHỈNH --- *@
<style>
    :root {
        --primary: #4f46e5;
        --bg-body: #f8f9fa;
    }

    body {
        background-color: var(--bg-body);
    }

    /* Header Card */
    .header-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(0,0,0,0.05);
        border-radius: 1rem;
        padding: 1.5rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        margin-bottom: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .header-icon {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, var(--primary) 0%, #4338ca 100%);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        box-shadow: 0 4px 10px rgba(79, 70, 229, 0.3);
    }

    /* Content Card */
    .content-card {
        background: white;
        border-radius: 1.5rem;
        padding: 3rem 2rem;
        box-shadow: 0 10px 40px rgba(0,0,0,0.04);
        border: 1px solid #e2e8f0;
        text-align: center;
        max-width: 600px;
        margin: 0 auto;
    }

    /* Status Icon Large */
    .status-icon-lg {
        font-size: 4rem;
        margin-bottom: 1.5rem;
        display: inline-block;
        width: 100px;
        height: 100px;
        line-height: 100px;
        border-radius: 50%;
        background-color: #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-left: auto;
        margin-right: auto;
    }

    .status-active {
        color: #10b981;
        background-color: #ecfdf5;
    }

    .status-inactive {
        color: #64748b;
        background-color: #f1f5f9;
    }

    /* Buttons */
    .btn-action-lg {
        padding: 0.8rem 2rem;
        border-radius: 50rem;
        font-weight: 700;
        font-size: 1rem;
        transition: all 0.2s;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

        .btn-action-lg:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

    .btn-primary-soft {
        background: linear-gradient(135deg, var(--primary) 0%, #4338ca 100%);
        color: white;
        border: none;
    }

        .btn-primary-soft:hover {
            color: white;
        }

    .btn-outline-soft {
        background: white;
        border: 2px solid #e2e8f0;
        color: #475569;
    }

        .btn-outline-soft:hover {
            border-color: #cbd5e1;
            color: #1e293b;
            background-color: #f8fafc;
        }
</style>

<div class="container-fluid py-4 animate__animated animate__fadeIn" style="padding-left: 2rem; padding-right: 2rem;">

    @* --- HEADER --- *@
    <div class="header-card">
        <div class="d-flex align-items-center gap-3">
            <div class="header-icon">
                <i class="bi bi-shield-check"></i>
            </div>
            <div>
                <h4 class="fw-bold text-dark mb-0">Xác thực 2 yếu tố (2FA)</h4>
                <small class="text-muted">Tăng cường bảo mật tối đa cho tài khoản của bạn</small>
            </div>
        </div>
    </div>

    @* --- CONTENT --- *@
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="content-card">

                @if (Model.Is2faEnabled)
                {
                    // --- TRẠNG THÁI: ĐÃ BẬT ---
                    <div class="status-icon-lg status-active animate__animated animate__bounceIn">
                        <i class="bi bi-shield-lock-fill"></i>
                    </div>
                    <h3 class="fw-bold text-dark mb-2">Hệ thống đang được bảo vệ</h3>
                    <p class="text-muted mb-5 mx-auto" style="max-width: 400px;">
                        Tài khoản của bạn đã kích hoạt xác thực 2 lớp. Hacker sẽ không thể truy cập ngay cả khi biết mật khẩu.
                    </p>

                    <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
                        <a asp-page="./GenerateRecoveryCodes" class="btn btn-outline-soft btn-action-lg">
                            <i class="bi bi-qr-code me-2"></i> Lấy mã khôi phục
                        </a>
                        <a asp-page="./Disable2fa" class="btn btn-danger btn-action-lg border-0 shadow-sm" style="background-color: #fee2e2; color: #ef4444;">
                            <i class="bi bi-power me-2"></i> Tắt bảo vệ
                        </a>
                    </div>
                }
                else
                {
                    // --- TRẠNG THÁI: CHƯA BẬT ---
                    <div class="status-icon-lg status-inactive">
                        <i class="bi bi-unlock-fill"></i>
                    </div>
                    <h3 class="fw-bold text-dark mb-2">Chưa kích hoạt 2FA</h3>
                    <p class="text-muted mb-4 mx-auto" style="max-width: 450px;">
                        Kích hoạt ngay để thêm một lớp khóa an toàn. Mỗi lần đăng nhập, bạn sẽ cần nhập mã xác thực từ điện thoại.
                    </p>

                    <div class="alert alert-warning border-0 rounded-4 p-3 mb-5 text-start d-inline-block shadow-sm" style="max-width: 450px;">
                        <div class="d-flex gap-3 align-items-center">
                            <i class="bi bi-phone-vibrate fs-3 text-warning"></i>
                            <div class="small text-dark opacity-75 lh-sm">
                                <strong>Khuyến nghị:</strong> Sử dụng ứng dụng
                                <span class="fw-bold text-primary">Google Authenticator</span> hoặc
                                <span class="fw-bold text-primary">Microsoft Authenticator</span>.
                            </div>
                        </div>
                    </div>

                    <div>
                        <a asp-page="./EnableAuthenticator" class="btn btn-primary-soft btn-action-lg">
                            THIẾT LẬP NGAY <i class="bi bi-arrow-right ms-2"></i>
                        </a>
                    </div>
                }

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}