@page
@model Tour_2040.Areas.Identity.Pages.Account.Manage.PersonalDataModel
@{
    ViewData["Title"] = "Quyền dữ liệu số";
}

@* --- CSS TÙY CHỈNH --- *@
<style>
    :root {
        --primary: #4f46e5;
        --bg-body: #f8f9fa;
    }

    body {
        background-color: var(--bg-body);
    }

    /* Header Card */
    .header-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(0,0,0,0.05);
        border-radius: 1rem;
        padding: 1.5rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        margin-bottom: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .header-icon {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, var(--primary) 0%, #4338ca 100%);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        box-shadow: 0 4px 10px rgba(79, 70, 229, 0.3);
    }

    /* Action Card */
    .action-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2.5rem;
        border: 1px solid #e2e8f0;
        text-align: center;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        height: 100%;
        position: relative;
        overflow: hidden;
    }

        .action-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.05);
        }

    .icon-box {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        margin: 0 auto 1.5rem;
        transition: transform 0.3s;
    }

    .action-card:hover .icon-box {
        transform: scale(1.1);
    }

    /* Theme colors for cards */
    .card-download .icon-box {
        background-color: #eef2ff;
        color: var(--primary);
    }

    .card-delete .icon-box {
        background-color: #fef2f2;
        color: #ef4444;
    }

    .card-delete:hover {
        border-color: #fca5a5;
    }

    /* Buttons */
    .btn-action {
        padding: 0.8rem 1.5rem;
        border-radius: 50rem;
        font-weight: 700;
        width: 100%;
        transition: all 0.2s;
    }

    .btn-download {
        background-color: var(--primary);
        color: white;
        border: none;
        box-shadow: 0 4px 15px rgba(79, 70, 229, 0.2);
    }

        .btn-download:hover {
            background-color: #4338ca;
            transform: translateY(-2px);
            color: white;
        }

    .btn-delete {
        background-color: white;
        color: #ef4444;
        border: 2px solid #fee2e2;
    }

        .btn-delete:hover {
            background-color: #ef4444;
            color: white;
            border-color: #ef4444;
        }
</style>

<div class="container-fluid py-4 animate__animated animate__fadeIn" style="padding-left: 2rem; padding-right: 2rem;">

    @* --- HEADER --- *@
    <div class="header-card">
        <div class="d-flex align-items-center gap-3">
            <div class="header-icon">
                <i class="bi bi-server"></i>
            </div>
            <div>
                <h4 class="fw-bold text-dark mb-0">Trung tâm dữ liệu cá nhân</h4>
                <small class="text-muted">Kiểm soát toàn quyền đối với thông tin bạn đã chia sẻ</small>
            </div>
        </div>
    </div>

    @* --- INFO ALERT --- *@
    <div class="row justify-content-center mb-4">
        <div class="col-lg-8">
            <div class="alert alert-light border-0 shadow-sm rounded-4 d-flex gap-3 align-items-center p-3">
                <div class="bg-primary text-white rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                    <i class="bi bi-shield-lock-fill"></i>
                </div>
                <div>
                    <strong class="text-dark">Cam kết bảo mật:</strong>
                    <p class="mb-0 small text-muted">Chúng tôi tuân thủ nghiêm ngặt các quy định bảo vệ dữ liệu (GDPR). Mọi thông tin tải xuống đều được mã hóa chuẩn.</p>
                </div>
            </div>
        </div>
    </div>

    @* --- ACTION CARDS --- *@
    <div class="row g-4 justify-content-center">

        @* Card 1: Tải xuống *@
        <div class="col-md-5 col-lg-4">
            <div class="action-card card-download">
                <div class="icon-box">
                    <i class="bi bi-cloud-arrow-down-fill"></i>
                </div>
                <h5 class="fw-bold text-dark mb-2">Tải xuống bản sao</h5>
                <p class="text-muted small mb-4 px-3">
                    Nhận file chứa toàn bộ lịch sử tour, giao dịch và thông tin cá nhân của bạn dưới dạng JSON/CSV.
                </p>
                <form id="download-data" asp-page="DownloadPersonalData" method="post">
                    <button type="submit" class="btn btn-action btn-download">
                        TẠO FILE LƯU TRỮ
                    </button>
                </form>
            </div>
        </div>

        @* Card 2: Xóa tài khoản *@
        <div class="col-md-5 col-lg-4">
            <div class="action-card card-delete">
                <div class="icon-box">
                    <i class="bi bi-trash3-fill"></i>
                </div>
                <h5 class="fw-bold text-dark mb-2">Xóa tài khoản</h5>
                <p class="text-muted small mb-4 px-3">
                    Hành động vĩnh viễn. Mọi dữ liệu, điểm thưởng và voucher sẽ bị xóa khỏi hệ thống và không thể khôi phục.
                </p>
                <form id="delete-data" asp-page="DeletePersonalData" method="post">
                    <button type="submit" class="btn btn-action btn-delete">
                        YÊU CẦU XÓA
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}