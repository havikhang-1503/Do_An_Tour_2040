@page
@model RegisterModel

@{
    ViewData["Title"] = "Đăng ký";
}

@*
  Folder: Areas/Identity/Pages/Account
  File path: Areas/Identity/Pages/Account/Register.cshtml
  File name: Register.cshtml
  Labels: A(UI Pastel Glass), B(Full width edge-to-edge), C(Dense grid 2-3 cols), D(Keep fields), E(FIX @@media Razor)
  Notes:
    - Chỉ chỉnh giao diện/bố cục
    - Không đổi form/field/validation
*@

<style>
    :root {
        --bg1: #F6F8FF;
        --bg2: #EEF2FF;
        --text: #0f172a;
        --muted: #64748b;
        --border: 1px solid rgba(226,232,240,.92);
        --shadow: 0 22px 52px rgba(2,6,23,.12);
        --primary: #2563eb;
        /* ✅ sát lề hơn */
        --outer-gutter: clamp(10px, 1.8vw, 22px);
        --radius-xl: 30px;
        --radius-lg: 16px;
    }

    body {
        background: linear-gradient(180deg, var(--bg1), var(--bg2)) !important;
        color: var(--text);
        font-family: Inter,system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    }

    /* Full nền màu */
    .auth-bg {
        min-height: calc(100vh - 72px);
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding: 12px var(--outer-gutter) 18px;
        position: relative;
        overflow: hidden;
    }

        .auth-bg::before {
            content: "";
            position: absolute;
            inset: -140px;
            background: radial-gradient(900px 420px at 20% 10%, rgba(37,99,235,.12), transparent 60%), radial-gradient(700px 380px at 80% 30%, rgba(34,197,94,.10), transparent 62%), radial-gradient(860px 520px at 60% 95%, rgba(245,158,11,.10), transparent 60%);
            filter: blur(2px);
            pointer-events: none;
        }

    /* ✅ Tràn full 2 bên */
    .auth-card {
        width: 100%;
        max-width: none; /* quan trọng */
        border-radius: var(--radius-xl);
        overflow: hidden;
        background: rgba(255,255,255,.86);
        border: 1px solid rgba(226,232,240,.85);
        box-shadow: var(--shadow);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        position: relative;
        z-index: 2;
    }

    /* ✅ padding gọn để tiết kiệm diện tích */
    .auth-form {
        background: rgba(255,255,255,.92);
        padding: 18px 18px 16px;
    }

    /* Header tối giản và thấp */
    .head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 12px;
    }

    .head-left {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
    }

    .icon-hero {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        background: rgba(37,99,235,.10);
        border: 1px solid rgba(37,99,235,.16);
        box-shadow: 0 10px 18px rgba(2,6,23,.08);
        flex: 0 0 auto;
    }

    .title-wrap {
        min-width: 0;
    }

    .title {
        font-weight: 1000;
        letter-spacing: -.3px;
        margin: 0;
        color: #0b1220;
        font-size: 1.2rem;
        line-height: 1.1;
    }

    .sub {
        margin: .2rem 0 0;
        font-size: .82rem;
        font-weight: 800;
        color: rgba(100,116,139,.92);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 60vw;
    }

    /* Inputs: thấp + gọn */
    .form-label {
        font-size: .74rem;
        font-weight: 950;
        color: rgba(100,116,139,.92) !important;
        margin: 0 0 4px 6px;
        text-transform: none;
        letter-spacing: .2px;
    }

    .form-control {
        border-radius: var(--radius-lg) !important;
    }

    .input-soft {
        background: rgba(248,250,252,.96) !important;
        border: 1px solid rgba(226,232,240,.9) !important;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.8);
        padding: .55rem .9rem;
        font-weight: 750;
        font-size: .92rem;
    }

        .input-soft:focus {
            border-color: rgba(37,99,235,.35) !important;
            box-shadow: 0 0 0 4px rgba(37,99,235,.10) !important;
            background: #fff !important;
            outline: none;
        }

    .hint {
        font-size: .7rem;
        font-weight: 850;
        color: rgba(100,116,139,.88);
        margin: 6px 0 0 6px;
    }

    /* ✅ Grid tiết kiệm diện tích: 2 cột (md), 3 cột (xl) */
    .form-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 10px 12px;
        align-items: start;
    }

    @@media (min-width: 768px) {
        .form-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (min-width: 1200px) {
        .form-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .auth-form {
            padding: 18px 22px 16px;
        }
    }

    /* Span helper */
    .span-2 {
        grid-column: span 2;
    }

    .span-3 {
        grid-column: span 3;
    }

    @@media (max-width: 991.98px) {
        .span-2, .span-3 {
            grid-column: span 1;
        }
        /* mobile auto full */
    }

    /* Buttons */
    .btn-pill {
        border-radius: 999px !important;
        font-weight: 1000;
        box-shadow: 0 16px 28px rgba(2,6,23,.12);
        letter-spacing: .25px;
        white-space: nowrap;
    }

    .btn-primary-pill {
        background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
        border: none;
        padding-top: .72rem;
        padding-bottom: .72rem;
        font-size: .95rem;
    }

    .btn-outline-pill {
        border-radius: 999px !important;
        font-weight: 950;
        border: 1px solid rgba(15,23,42,.22) !important;
        background: rgba(255,255,255,.86);
        padding: .52rem 1.05rem;
        font-size: .9rem;
    }

    .foot {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-top: 10px;
        flex-wrap: wrap;
    }
</style>

<div class="auth-bg">
    <div class="auth-card">
        <div class="auth-form">

            <div class="head">
                <div class="head-left">
                    <div class="icon-hero">
                        <i class="bi bi-person-plus-fill text-primary fs-5"></i>
                    </div>
                    <div class="title-wrap">
                        <h2 class="title">Đăng ký</h2>
                        <div class="sub">Điền nhanh, gọn, khỏi lướt mệt</div>
                    </div>
                </div>
            </div>

            <form asp-route-returnUrl="@Model.ReturnUrl" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                <div class="form-grid">
                    <!-- HỌ TÊN -->
                    <div>
                        <label class="form-label">Họ và tên</label>
                        <input asp-for="Input.HoTen" class="form-control input-soft" placeholder="Nguyễn Văn A"
                               oninput="this.value = this.value.replace(/[0-9]/g, '')" />
                        <span asp-validation-for="Input.HoTen" class="text-danger small ms-1"></span>
                    </div>

                    <!-- SĐT -->
                    <div>
                        <label class="form-label">Số điện thoại</label>
                        <input asp-for="Input.PhoneNumber" class="form-control input-soft" placeholder="09xxxx (10 số)"
                               maxlength="10" type="tel"
                               oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                        <span asp-validation-for="Input.PhoneNumber" class="text-danger small ms-1"></span>
                    </div>

                    <!-- NGÀY SINH -->
                    <div>
                        <label class="form-label">Ngày sinh</label>
                        <input asp-for="Input.NgaySinh" class="form-control input-soft"
                               max="@DateTime.Now.AddYears(-16).ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="Input.NgaySinh" class="text-danger small ms-1"></span>
                        <div class="hint">* Phải đủ 16 tuổi</div>
                    </div>

                    <!-- CCCD -->
                    <div>
                        <label class="form-label">CCCD / CMND</label>
                        <input asp-for="Input.CCCD" class="form-control input-soft" placeholder="12 số định danh"
                               maxlength="12" type="tel"
                               oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                        <span asp-validation-for="Input.CCCD" class="text-danger small ms-1"></span>
                    </div>

                    <!-- EMAIL (full hàng để khỏi bị dài khó nhìn) -->
                    <div class="span-2 span-3">
                        <label class="form-label">Email</label>
                        <input asp-for="Input.Email" class="form-control input-soft" placeholder="email@example.com" />
                        <span asp-validation-for="Input.Email" class="text-danger small ms-1"></span>
                    </div>

                    <!-- PASSWORD -->
                    <div>
                        <label class="form-label">Mật khẩu</label>
                        <input asp-for="Input.Password" class="form-control input-soft" placeholder="******" />
                        <span asp-validation-for="Input.Password" class="text-danger small ms-1"></span>
                    </div>

                    <!-- CONFIRM -->
                    <div>
                        <label class="form-label">Xác nhận mật khẩu</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control input-soft" placeholder="******" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small ms-1"></span>
                    </div>

                    <!-- ẢNH CCCD (full hàng) -->
                    <div class="span-2 span-3">
                        <label class="form-label">Ảnh minh chứng CCCD</label>
                        <input asp-for="Input.AnhCCCD" type="file" class="form-control input-soft" accept="image/*" />
                        <span asp-validation-for="Input.AnhCCCD" class="text-danger small ms-1"></span>
                    </div>

                    <!-- BUTTON (full hàng) -->
                    <div class="span-2 span-3">
                        <button type="submit" class="btn btn-primary-pill btn-pill w-100 mt-1">
                            TẠO TÀI KHOẢN <i class="bi bi-arrow-right ms-2"></i>
                        </button>

                        <div class="foot">
                            <span class="text-muted small fw-bold">Đã có tài khoản?</span>
                            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="btn btn-outline-pill">
                                Về đăng nhập
                            </a>
                        </div>
                    </div>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
