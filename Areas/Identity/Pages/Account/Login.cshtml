@page
@model LoginModel
@{
    ViewData["Title"] = "Cổng đăng nhập Hoàng Gia";
}

@*
  Folder: Areas/Identity/Pages/Account
  File path: Areas/Identity/Pages/Account/Login.cshtml
  File name: Login.cshtml
  Labels: A(UI Pastel Glass), B(Remove dark banner), C(Pill buttons), D(Responsive)
  Notes:
    - FIX: bỏ mảng xanh đậm -> thay bằng brand panel nhẹ (pastel glass) + pattern mờ
*@

<style>
    :root {
        --bg: #F6F8FF;
        --text: #0f172a;
        --muted: #64748b;
        --border: 1px solid rgba(226,232,240,.92);
        --shadow: 0 26px 60px rgba(2,6,23,.14);
        --primary: #2563eb;
        --primary-soft: rgba(37,99,235,.12);
        --primary-soft2: rgba(37,99,235,.18);
        --outer-gutter: clamp(14px, 3vw, 56px);
        --radius-xl: 34px;
        --radius-lg: 26px;
    }

    body {
        background: var(--bg) !important;
        color: var(--text);
        font-family: Inter,system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    }

    /* nền nhẹ kiểu index */
    .auth-bg {
        min-height: 88vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 22px var(--outer-gutter);
        position: relative;
        overflow: hidden;
    }

        .auth-bg::before {
            content: "";
            position: absolute;
            inset: -120px;
            background: radial-gradient(900px 420px at 20% 10%, rgba(37,99,235,.12), transparent 60%), radial-gradient(700px 380px at 80% 30%, rgba(34,197,94,.10), transparent 62%), radial-gradient(860px 520px at 60% 95%, rgba(245,158,11,.10), transparent 60%);
            filter: blur(2px);
            pointer-events: none;
        }

    .login-split-card {
        width: min(1100px, 100%);
        border-radius: var(--radius-xl);
        overflow: hidden;
        background: rgba(255,255,255,.86);
        border: 1px solid rgba(226,232,240,.85);
        box-shadow: var(--shadow);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
    }

    /* BRAND PANEL: nhẹ, không tối */
    .login-brand {
        position: relative;
        padding: 3.25rem 3.1rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        background: linear-gradient(135deg, rgba(37,99,235,.12) 0%, rgba(255,255,255,.85) 55%, rgba(34,197,94,.10) 100%);
    }

        .login-brand::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(500px 300px at 10% 20%, rgba(37,99,235,.18), transparent 65%), radial-gradient(520px 320px at 85% 25%, rgba(245,158,11,.14), transparent 70%), radial-gradient(600px 360px at 50% 92%, rgba(34,197,94,.12), transparent 70%);
            opacity: .9;
            pointer-events: none;
        }

        .login-brand::after {
            content: "";
            position: absolute;
            inset: 0;
            background: url('https://images.unsplash.com/photo-1436491865332-7a61a109cc05?q=80&w=2074&auto=format&fit=crop') center/cover;
            opacity: 0.08; /* rất nhẹ */
            mix-blend-mode: multiply;
            pointer-events: none;
            filter: saturate(.9) contrast(1.02);
        }

    .brand-inner {
        position: relative;
        z-index: 1;
    }

    .brand-badge {
        display: inline-flex;
        align-items: center;
        gap: .6rem;
        padding: .65rem 1rem;
        border-radius: 999px;
        border: var(--border);
        background: rgba(255,255,255,.78);
        box-shadow: 0 12px 26px rgba(2,6,23,.08);
        font-weight: 950;
        color: #0b1220;
        width: fit-content;
    }

    .brand-title {
        font-weight: 1000;
        font-size: 2.15rem;
        line-height: 1.1;
        margin: 1rem 0 .85rem;
        color: #0b1220;
        letter-spacing: -.4px;
    }

    .brand-desc {
        color: rgba(15,23,42,.72);
        font-weight: 800;
        max-width: 420px;
    }

    .brand-stats {
        display: flex;
        gap: 14px;
        margin-top: 1.9rem;
        flex-wrap: wrap;
    }

    .stat {
        flex: 1 1 160px;
        background: rgba(255,255,255,.70);
        border: var(--border);
        border-radius: 18px;
        padding: 14px 14px;
        box-shadow: 0 10px 22px rgba(2,6,23,.06);
    }

        .stat h3 {
            margin: 0;
            font-weight: 1000;
            color: #0b1220;
        }

        .stat small {
            color: rgba(15,23,42,.62);
            font-weight: 900;
            letter-spacing: .6px;
            text-transform: uppercase;
            font-size: .72rem;
        }

    /* FORM PANEL */
    .login-form {
        background: rgba(255,255,255,.92);
        padding: 3.25rem 3rem;
    }

    .icon-hero {
        width: 64px;
        height: 64px;
        border-radius: 20px;
        display: grid;
        place-items: center;
        background: rgba(37,99,235,.10);
        border: 1px solid rgba(37,99,235,.16);
        box-shadow: 0 14px 24px rgba(2,6,23,.08);
        margin: 0 auto 12px;
    }

    .form-control {
        border-radius: 18px !important;
    }

    .input-soft {
        background: rgba(248,250,252,.96) !important;
        border: 1px solid rgba(226,232,240,.9) !important;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.8);
    }

        .input-soft:focus {
            border-color: rgba(37,99,235,.35) !important;
            box-shadow: 0 0 0 4px rgba(37,99,235,.10) !important;
            background: #fff !important;
        }

    /* nút pill đúng quy ước */
    .btn-pill {
        border-radius: 999px !important;
        font-weight: 1000;
        box-shadow: 0 18px 34px rgba(2,6,23,.12);
        letter-spacing: .3px;
        white-space: nowrap;
    }

    .btn-primary-pill {
        background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
        border: none;
    }

        .btn-primary-pill:hover {
            filter: brightness(.97);
        }

    .btn-outline-pill {
        border-radius: 999px !important;
        font-weight: 950;
        border: 1px solid rgba(15,23,42,.22) !important;
        background: rgba(255,255,255,.86);
    }

    @@media (max-width: 991.98px) {
        .login-form {
            padding: 2.4rem 1.6rem;
        }
    }
</style>

<div class="auth-bg">
    <div class="login-split-card row g-0 w-100">

        <!-- BRAND (nhẹ màu, không tối) -->
        <div class="col-lg-5 login-brand d-none d-lg-flex">
            <div class="brand-inner">
                <div class="brand-badge">
                    <i class="bi bi-stars text-primary"></i>
                    Royal Ascend Travel
                </div>

                <div class="brand-title">Tiếp tục hành trình đẳng cấp.</div>
                <div class="brand-desc">
                    Chào mừng trở lại. Điểm đến “xịn” không tự đặt, nên đăng nhập đi em 😌
                </div>

                <div class="brand-stats">
                    <div class="stat">
                        <h3>500+</h3>
                        <small>Tours</small>
                    </div>
                    <div class="stat">
                        <h3>10k+</h3>
                        <small>Hài lòng</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- FORM -->
        <div class="col-lg-7 login-form">
            <div class="text-center mb-4">
                <div class="icon-hero">
                    <i class="bi bi-airplane-engines-fill text-primary fs-2"></i>
                </div>
                <h2 class="fw-bold mb-1" style="color:#0b1220;">Đăng nhập</h2>
                <div class="text-muted fw-bold" style="font-size:.88rem;">Royal Ascend • Cổng truy cập hội viên</div>
            </div>

            <form id="account" method="post" class="mt-4">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control input-soft" placeholder="name@example.com" />
                    <label asp-for="Input.Email" class="text-muted">Email đăng nhập</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control input-soft" placeholder="Password" />
                    <label asp-for="Input.Password" class="text-muted">Mật khẩu</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label small text-muted fw-bold" asp-for="Input.RememberMe">
                            Duy trì đăng nhập
                        </label>
                    </div>

                    <a id="forgot-password" asp-page="./ForgotPassword"
                       class="small fw-bold text-primary text-decoration-none">
                        Quên mật khẩu?
                    </a>
                </div>

                <button id="login-submit" type="submit"
                        class="btn btn-primary-pill btn-pill w-100 py-3 fs-6">
                    KHÁM PHÁ NGAY <i class="bi bi-arrow-right ms-2"></i>
                </button>
            </form>

            <div class="text-center mt-4">
                <p class="text-muted small mb-2">Chưa là thành viên?</p>
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl"
                   class="btn btn-outline-pill px-4 py-2">
                    Đăng ký Membership
                </a>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
