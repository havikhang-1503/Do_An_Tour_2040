@* Folder: Views/DanhGiaTours
   File path: Views/DanhGiaTours/Create.cshtml
   File name: Create.cshtml
   Labels: A(User create), B(List reviews), C(Upload ảnh), D(Pill buttons)
   Mô tả: Người dùng đánh giá sau tour + xem danh sách đánh giá của lịch trình.
*@
@model Tour_2040.Models.DanhGiaTourCreateViewModel
@{
    ViewData["Title"] = "Đánh giá tour";
}

<style>
    :root {
        --outer-gutter: clamp(10px, 2vw, 28px);
        --bd: 1px solid rgba(226,232,240,.92);
        --shadow: 0 18px 40px rgba(2,6,23,.08);
        --r: 18px;
    }

    .page-shell {
        padding: 12px var(--outer-gutter);
    }

    .cardx {
        background: rgba(255,255,255,.9);
        backdrop-filter: blur(12px);
        border: var(--bd);
        border-radius: var(--r);
        box-shadow: var(--shadow);
    }

    .btn-pill {
        border-radius: 999px !important;
        font-weight: 900;
        padding: .55rem 1rem;
    }

    .thumb {
        width: 90px;
        height: 70px;
        object-fit: cover;
        border-radius: 14px;
        border: var(--bd);
    }

    .star-btn {
        cursor: pointer;
    }
</style>

<div class="page-shell">
    <div class="cardx p-3 p-md-4">

        <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
            <div>
                <div class="text-muted small mb-1"><i class="bi bi-star-fill text-warning"></i> Đánh giá</div>
                <div class="fw-bold fs-3">Đánh giá tour</div>
                <div class="text-muted">@Model.TenTourHoacLichTrinh</div>
            </div>
            <a asp-controller="Tours" asp-action="Index" class="btn btn-warning btn-pill">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>

        @if (TempData["ok"] != null)
        {
            <div class="alert alert-success rounded-4">@TempData["ok"]</div>
        }

        @if (!Model.CanDanhGia)
        {
            <div class="alert alert-warning rounded-4">
                @Model.ThongBao
            </div>
        }
        else
        {
            <form asp-action="Create" method="post" enctype="multipart/form-data" class="row g-3">
                <input type="hidden" asp-for="MaLichTrinh" />

                <div class="col-12">
                    <div class="fw-bold small text-muted mb-2">Chọn sao</div>
                    <input type="hidden" asp-for="SoSao" id="SoSaoInput" />
                    <div class="d-flex gap-2 flex-wrap">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span class="star-btn" data-val="@i" title="@i sao">
                                <i class="bi bi-star fs-2 text-muted"></i>
                            </span>
                        }
                    </div>
                    <span asp-validation-for="SoSao" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label class="fw-bold small text-muted mb-2">Bình luận</label>
                    <textarea asp-for="BinhLuan" class="form-control bg-light border-0 rounded-4 p-3" rows="4"
                              placeholder="Chia sẻ trải nghiệm của em..."></textarea>
                    <span asp-validation-for="BinhLuan" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label class="fw-bold small text-muted mb-2">Ảnh minh hoạ (tuỳ chọn)</label>
                    <input asp-for="TepHinhAnh" type="file" class="form-control rounded-pill" accept="image/*" />
                    <span asp-validation-for="TepHinhAnh" class="text-danger small"></span>
                </div>

                <div class="col-12 d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary btn-pill px-4">
                        <i class="bi bi-send"></i> Gửi đánh giá
                    </button>
                </div>
            </form>
        }

        <hr class="my-4" />

        <div class="fw-bold mb-2">Danh sách đánh giá (lịch trình này)</div>

        @if (Model.DanhSachDanhGia == null || Model.DanhSachDanhGia.Count == 0)
        {
            <div class="text-muted">Chưa có đánh giá nào.</div>
        }
        else
        {
            <div class="vstack gap-3">
                @foreach (var d in Model.DanhSachDanhGia)
                {
                    <div class="p-3 rounded-4" style="border:var(--bd); background: rgba(248,250,252,.7);">
                        <div class="d-flex flex-wrap justify-content-between gap-2 align-items-start">
                            <div class="fw-bold">@d.TenNguoiDung</div>
                            <div class="text-warning fw-bold">
                                <i class="bi bi-star-fill"></i> @d.SoSao
                                <span class="text-muted small ms-2">@d.NgayTao.ToString("dd/MM/yyyy")</span>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(d.BinhLuan))
                        {
                            <div class="mt-2">@d.BinhLuan</div>
                        }

                        <div class="d-flex flex-wrap align-items-center gap-2 mt-2">
                            @if (!string.IsNullOrWhiteSpace(d.HinhAnhUrl))
                            {
                                <a href="@d.HinhAnhUrl" target="_blank" class="text-decoration-none">
                                    <img class="thumb" src="@d.HinhAnhUrl" alt="Ảnh đánh giá" />
                                </a>
                            }

                            @if (d.IsOwner)
                            {
                                <div class="ms-auto d-flex gap-2">
                                    <a asp-action="Edit" asp-route-maDanhGia="@d.MaDanhGia" class="btn btn-primary btn-pill">
                                        <i class="bi bi-pencil"></i> Sửa
                                    </a>
                                    <a asp-action="Delete" asp-route-maDanhGia="@d.MaDanhGia" class="btn btn-danger btn-pill">
                                        <i class="bi bi-trash3"></i> Xoá
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const stars = document.querySelectorAll('.star-btn');
        const input = document.getElementById('SoSaoInput');

        function paint(val){
            stars.forEach(s=>{
                const v = parseInt(s.dataset.val);
                const icon = s.querySelector('i');
                if(v <= val){
                    icon.classList.remove('bi-star','text-muted');
                    icon.classList.add('bi-star-fill','text-warning');
                } else {
                    icon.classList.remove('bi-star-fill','text-warning');
                    icon.classList.add('bi-star','text-muted');
                }
            });
        }
        stars.forEach(s=>{
            s.addEventListener('click', ()=>{
                const val = parseInt(s.dataset.val);
                input.value = val;
                paint(val);
            });
        });
        paint(parseInt(input.value || "5"));
    </script>
}
