@* Folder: Views/DanhGiaTours
   File path: Views/DanhGiaTours/AdminTourDetails.cshtml
   File name: AdminTourDetails.cshtml
   Labels: A(Admin details), B(Stats 1-5 sao), C(Soft theme)
   Mô tả: Admin xem chi tiết đánh giá theo tour + thống kê sao.
*@
@model Tour_2040.Models.DanhGiaTourAdminTourDetailsViewModel
@{
    ViewData["Title"] = "Chi tiết đánh giá (Admin)";
}
<style>
    :root {
        --outer-gutter: clamp(10px, 2vw, 28px);
        --bd: 1px solid rgba(226,232,240,.92);
        --shadow: 0 18px 40px rgba(2,6,23,.08);
        --r: 18px;
    }

    .page-shell {
        padding: 12px var(--outer-gutter);
    }

    .wrap {
        max-width: 1200px;
        margin: 0 auto;
    }

    .cardx {
        background: rgba(255,255,255,.9);
        backdrop-filter: blur(12px);
        border: var(--bd);
        border-radius: var(--r);
        box-shadow: var(--shadow);
    }

    .btn-pill {
        border-radius: 999px !important;
        font-weight: 900;
        padding: .55rem 1rem;
    }

    .thumb {
        width: 96px;
        height: 72px;
        object-fit: cover;
        border-radius: 14px;
        border: var(--bd);
    }

    .stars {
        font-weight: 950;
        color: #b45309;
        white-space: nowrap;
    }
</style>

<div class="page-shell">
    <div class="wrap">

        <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
            <div>
                <div class="text-muted small mb-1"><i class="bi bi-shield-lock text-primary"></i> Admin / <b class="text-dark">@Model.TenTour</b></div>
                <div class="text-muted small">@Model.DiaDiem • @Model.GiaTour.ToString("N0") đ</div>
            </div>
            <a asp-action="Admin" class="btn btn-warning btn-pill"><i class="bi bi-arrow-left"></i> Quay lại</a>
        </div>

        <div class="cardx p-3 p-md-4 mb-3">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                <div class="fw-bold">Tổng: <span class="text-primary">@Model.TongDanhGia</span> đánh giá</div>
                <div class="stars"><i class="bi bi-star-fill"></i> @Model.DiemTrungBinh.ToString("0.00")</div>
            </div>
            <div class="text-muted small mt-2">
                Breakdown: 5★ (@Model.Sao5), 4★ (@Model.Sao4), 3★ (@Model.Sao3), 2★ (@Model.Sao2), 1★ (@Model.Sao1)
            </div>
        </div>

        <div class="cardx p-3 p-md-4">
            @if (Model.DanhSachDanhGia == null || Model.DanhSachDanhGia.Count == 0)
            {
                <div class="text-muted fw-bold">Chưa có đánh giá nào.</div>
            }
            else
            {
                <div class="vstack gap-3">
                    @foreach (var d in Model.DanhSachDanhGia)
                    {
                        <div class="p-3 rounded-4" style="border:var(--bd); background: rgba(248,250,252,.72);">
                            <div class="d-flex justify-content-between align-items-start gap-2">
                                <div>
                                    <div class="fw-bold">@d.TenNguoiDung</div>
                                    <div class="text-muted small">@d.NgayDanhGia.ToString("dd/MM/yyyy") • Lịch trình: @d.MaLichTrinh</div>
                                </div>
                                <div class="stars"><i class="bi bi-star-fill"></i> @d.SoSao</div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(d.BinhLuan))
                            {
                                <div class="mt-2 fw-semibold">@d.BinhLuan</div>
                            }

                            @if (!string.IsNullOrWhiteSpace(d.HinhAnhUrl))
                            {
                                <div class="mt-2">
                                    <a href="@d.HinhAnhUrl" target="_blank" class="text-decoration-none">
                                        <img class="thumb" src="@d.HinhAnhUrl" alt="Ảnh đánh giá" />
                                    </a>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

    </div>
</div>
