@* Folder: Views/DanhGiaTours
   File path: Views/DanhGiaTours/AdminIndex.cshtml
   File name: AdminIndex.cshtml
   Labels: A(Admin dashboard), B(Dropdown actions), C(Stats)
   Mô tả: Admin xem tổng quan đánh giá + thao tác dropdown.
*@
@model Tour_2040.Models.DanhGiaTourIndexViewModels
@{
    ViewData["Title"] = "Quản trị đánh giá tour";
}

<style>
    :root {
        --outer-gutter: clamp(10px, 2vw, 28px);
        --bd: 1px solid rgba(226,232,240,.92);
        --shadow: 0 18px 40px rgba(2,6,23,.08);
        --r: 18px;
    }

    .page-shell {
        padding: 12px var(--outer-gutter);
    }

    .cardx {
        background: rgba(255,255,255,.9);
        backdrop-filter: blur(12px);
        border: var(--bd);
        border-radius: var(--r);
        box-shadow: var(--shadow);
    }

    .btn-pill {
        border-radius: 999px !important;
        font-weight: 900;
        padding: .55rem 1rem;
    }

    .table-modern thead th {
        font-size: .72rem;
        letter-spacing: .5px;
        text-transform: uppercase;
        color: #64748b;
        font-weight: 950;
    }
</style>

<div class="page-shell">
    <div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-2">
        <div>
            <div class="text-muted small mb-1"><i class="bi bi-shield-lock text-primary"></i> Admin / <b class="text-dark">Đánh giá</b></div>
            <div class="fw-bold fs-3 mb-0">Quản trị đánh giá tour</div>
            <div class="text-muted">Thống kê nhanh và truy cập chi tiết đánh giá theo tour.</div>
        </div>
        <a asp-action="Public" class="btn btn-light btn-pill"><i class="bi bi-eye"></i> Xem Public</a>
    </div>

    <div class="row g-2 mb-2">
        <div class="col-md-4">
            <div class="cardx p-3">
                <div class="text-muted small fw-bold">TỔNG ĐÁNH GIÁ</div>
                <div class="fw-bold fs-3">@Model.TongDanhGia</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="cardx p-3">
                <div class="text-muted small fw-bold">ĐIỂM TRUNG BÌNH</div>
                <div class="fw-bold fs-3">@Model.DiemTrungBinh</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="cardx p-3">
                <div class="text-muted small fw-bold">ĐÁNH GIÁ 5★</div>
                <div class="fw-bold fs-3">@Model.DanhGiaNamSao</div>
            </div>
        </div>
    </div>

    <div class="cardx p-2 p-md-3 mb-2">
        <form method="get" class="d-flex flex-wrap gap-2 align-items-center">
            <input type="hidden" name="action" value="Admin" />
            <div class="input-group" style="max-width:420px;">
                <span class="input-group-text bg-white" style="border-radius:999px 0 0 999px;"><i class="bi bi-search"></i></span>
                <input name="tuKhoa" value="@Model.TuKhoa" class="form-control" placeholder="Tìm mã tour / tên / địa điểm..." style="border-radius:0 999px 999px 0;" />
            </div>

            <select name="trangThai" class="form-select" style="max-width:200px; border-radius:999px;">
                <option value="tatca" selected="@(Model.TrangThai == "tatca" ? "selected" : null)">Tất cả</option>
                <option value="dadanhgia" selected="@(Model.TrangThai == "dadanhgia" ? "selected" : null)">Đã có đánh giá</option>
                <option value="chuadanhgia" selected="@(Model.TrangThai == "chuadanhgia" ? "selected" : null)">Chưa có đánh giá</option>
            </select>

            <select name="soSao" class="form-select" style="max-width:160px; border-radius:999px;">
                <option value="" selected="@(Model.SoSaoLoc == null ? "selected" : null)">Tất cả sao</option>
                @for (int i = 1; i <= 5; i++)
                {
                    <option value="@i" selected="@(Model.SoSaoLoc == i ? "selected" : null)">@i sao</option>
                }
            </select>

            <button class="btn btn-primary btn-pill"><i class="bi bi-funnel"></i> Lọc</button>
            <a asp-action="Admin" class="btn btn-warning btn-pill"><i class="bi bi-arrow-counterclockwise"></i> Reset</a>
        </form>
    </div>

    <div class="cardx p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th>Mã tour</th>
                        <th>Tên tour</th>
                        <th>Địa điểm</th>
                        <th class="text-center">Số đánh giá</th>
                        <th class="text-center">Điểm TB</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.DanhSachDong)
                    {
                        <tr>
                            <td class="fw-bold text-primary font-monospace">@r.MaTour</td>
                            <td class="fw-semibold">@r.TenTour</td>
                            <td class="text-muted">@r.DiaDiem</td>
                            <td class="text-center">
                                <span class="badge rounded-pill @(r.SoLuongDanhGia > 0 ? "bg-success" : "bg-secondary")">@r.SoLuongDanhGia</span>
                            </td>
                            <td class="text-center text-warning fw-bold">
                                <i class="bi bi-star-fill"></i> @r.DiemTrungBinh.ToString("0.00")
                            </td>
                            <td class="text-end">
                                <div class="dropdown">
                                    <button class="btn btn-light btn-pill dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-three-dots"></i> Thao tác
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow">
                                        <li>
                                            <a class="dropdown-item" asp-action="AdminTourDetails" asp-route-maTour="@r.MaTour">
                                                <i class="bi bi-bar-chart-line me-2"></i> Chi tiết & thống kê
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Tours" asp-action="Details" asp-route-id="@r.MaTour">
                                                <i class="bi bi-eye me-2"></i> Xem tour
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="p-3 d-flex justify-content-between align-items-center">
            <div class="text-muted small fw-bold">Trang @Model.Trang / @Model.TongSoTrang • Tổng dòng: @Model.TongSoDong</div>
            <div class="d-flex gap-2">
                @{
                    var prev = Model.Trang - 1;
                    var next = Model.Trang + 1;
                }
                <a class="btn btn-light btn-pill px-3 @(Model.Trang <= 1 ? "disabled" : "")"
                   href="@Url.Action("Admin", new { tuKhoa = Model.TuKhoa, trangThai = Model.TrangThai, soSao = Model.SoSaoLoc, trang = prev, kichThuocTrang = Model.KichThuocTrang })">
                    <i class="bi bi-chevron-left"></i>
                </a>
                <a class="btn btn-light btn-pill px-3 @(Model.Trang >= Model.TongSoTrang ? "disabled" : "")"
                   href="@Url.Action("Admin", new { tuKhoa = Model.TuKhoa, trangThai = Model.TrangThai, soSao = Model.SoSaoLoc, trang = next, kichThuocTrang = Model.KichThuocTrang })">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </div>
        </div>
    </div>
</div>
