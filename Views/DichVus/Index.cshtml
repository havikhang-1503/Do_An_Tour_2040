@* 
   Folder: Views/DichVus
   File path: Views/DichVus/Index.cshtml
   File name: Index.cshtml
   Label: V-DichVu-Index
   Mô tả: Danh sách dịch vụ - UI glass + pill + lọc/tìm kiếm chuẩn tham số controller.
   FIX: Đồng bộ searchString/loai/trangThai + ViewData CurrentFilter/LoaiFilter/TrangThaiFilter.
*@

@model IEnumerable<Tour_2040.Models.DichVu>

@{
    ViewData["Title"] = "Dịch vụ";

    // Đồng bộ theo Controller
    var searchString = (ViewData["CurrentFilter"] as string) ?? "";
    var loai = (ViewData["LoaiFilter"] as string) ?? "";
    var trangThai = (ViewData["TrangThaiFilter"] as string) ?? "";

    var total = Model?.Count() ?? 0;
    var active = Model?.Count(x => x.TrangThai == "Active" || x.TrangThai == "Còn") ?? 0;
    var inactive = total - active;

    // Dropdown loại dịch vụ: lấy từ dữ liệu thật để khỏi hardcode
    var loaiList = (Model ?? Enumerable.Empty<Tour_2040.Models.DichVu>())
        .Select(x => x.LoaiDichVu)
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct()
        .OrderBy(x => x)
        .ToList();
}

<style>
    :root {
        --bg-system: #F8F8FF;
        --text-main: #0f172a;
        --text-muted: #64748b;
        --border-thin: 1px solid #e2e8f0;
        --shadow: 0 12px 30px rgba(2, 6, 23, .06);
        --blue: #2563eb; /* confirm */
        --green: #16a34a; /* success */
        --red: #ef4444; /* danger */
        --yellow: #f59e0b; /* back */

        --btn-grey: #f1f5f9;
        --btn-grey-hover: #e2e8f0;
    }

    body {
        background: var(--bg-system) !important;
        color: var(--text-main);
        font-family: Inter,system-ui;
    }

    .card-glass {
        background: rgba(255,255,255,.92);
        border: var(--border-thin);
        border-radius: 20px;
        box-shadow: var(--shadow);
        backdrop-filter: blur(10px);
    }

    .btn-pill {
        border-radius: 999px !important;
        font-weight: 900;
        padding: .55rem 1rem;
        box-shadow: 0 10px 18px rgba(2,6,23,.08);
    }

    .btn-confirm {
        background: linear-gradient(135deg,var(--blue),#4f46e5);
        border: none;
        color: #fff;
    }

    .btn-successx {
        background: linear-gradient(135deg,var(--green),#22c55e);
        border: none;
        color: #fff;
    }

    .btn-dangerx {
        background: linear-gradient(135deg,var(--red),#fb7185);
        border: none;
        color: #fff;
    }

    .btn-back {
        background: linear-gradient(135deg,var(--yellow),#fbbf24);
        border: none;
        color: #111827;
    }

    .btn-grey {
        background: var(--btn-grey);
        border: var(--border-thin);
        color: var(--text-muted);
    }

        .btn-grey:hover {
            background: var(--btn-grey-hover);
            color: var(--text-main);
            border-color: #cbd5e1;
        }

    .pill-filter {
        background: #fff;
        border: var(--border-thin);
        border-radius: 999px;
        padding: 10px 12px;
        display: flex;
        align-items: center;
        gap: 10px;
        box-shadow: 0 10px 18px rgba(2,6,23,.05);
        flex-wrap: wrap;
    }

        .pill-filter input, .pill-filter select {
            border: none;
            outline: none;
            background: transparent;
            font-size: .88rem;
        }

        .pill-filter input {
            min-width: 260px;
        }

        .pill-filter select {
            font-weight: 800;
            color: var(--text-muted);
            cursor: pointer;
        }

    .kpi {
        border: var(--border-thin);
        border-radius: 16px;
        background: #fff;
        padding: 14px 16px;
        display: flex;
        align-items: center;
        gap: 14px;
        box-shadow: 0 10px 18px rgba(2,6,23,.05);
    }

        .kpi .ico {
            width: 44px;
            height: 44px;
            border-radius: 14px;
            border: var(--border-thin);
            display: flex;
            align-items: center;
            justify-content: center;
            background: #fcfcff;
            font-size: 1.1rem;
        }

        .kpi .t {
            font-size: .72rem;
            text-transform: uppercase;
            letter-spacing: .35px;
            color: var(--text-muted);
            font-weight: 900;
        }

        .kpi .v {
            font-weight: 1000;
            font-size: 1.2rem;
        }

    .table-wrap {
        border: var(--border-thin);
        border-radius: 18px;
        overflow: hidden;
        background: #fff;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead th {
        background: #fcfcff;
        border-bottom: var(--border-thin);
        padding: 14px 16px;
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .35px;
        color: var(--text-muted);
        font-weight: 1000;
        white-space: nowrap;
    }

    tbody td {
        border-bottom: var(--border-thin);
        padding: 14px 16px;
        font-size: .92rem;
        vertical-align: middle;
    }

    tbody tr:hover {
        background: #f8fafc;
    }

    .badge-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        border-radius: 999px;
        font-weight: 900;
        font-size: .75rem;
        border: 1px solid transparent;
        background: #fff;
        white-space: nowrap;
    }

    .badge-ok {
        background: rgba(34,197,94,.10);
        border-color: rgba(34,197,94,.22);
        color: #16a34a;
    }

    .badge-bad {
        background: rgba(239,68,68,.10);
        border-color: rgba(239,68,68,.22);
        color: #dc2626;
    }

    .badge-type {
        background: rgba(37,99,235,.10);
        border-color: rgba(37,99,235,.22);
        color: #2563eb;
    }

    .money {
        font-weight: 1000;
        color: #2563eb;
    }

    .actions {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        flex-wrap: wrap;
    }

    .btn-mini {
        border-radius: 999px !important;
        padding: .38rem .75rem;
        font-weight: 900;
        border: var(--border-thin);
        background: #fff;
        color: var(--text-main);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

        .btn-mini:hover {
            background: #f1f5f9;
        }

    .result-note {
        color: var(--text-muted);
        font-weight: 800;
        font-size: .9rem;
    }
</style>

<div class="container-fluid py-4 px-lg-5 animate__animated animate__fadeIn">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-3">
        <div>
            <div class="text-muted small mb-1"><i class="bi bi-grid"></i> Hệ thống / <b class="text-dark">Dịch vụ</b></div>
            <h3 class="fw-bold mb-1">Quản lý dịch vụ</h3>
            <div class="text-muted">Lọc theo từ khóa, loại, trạng thái. Có lọc nhanh realtime luôn.</div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Create" class="btn btn-pill btn-successx">
                <i class="bi bi-plus-circle"></i> Thêm dịch vụ
            </a>
            <a asp-action="Index" class="btn btn-pill btn-grey">
                <i class="bi bi-arrow-clockwise"></i> Làm mới
            </a>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <div class="kpi">
                <div class="ico text-primary"><i class="bi bi-box-seam"></i></div>
                <div>
                    <div class="t">Tổng dịch vụ</div>
                    <div class="v">@total</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="kpi">
                <div class="ico text-success"><i class="bi bi-check2-circle"></i></div>
                <div>
                    <div class="t">Đang hoạt động</div>
                    <div class="v">@active</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="kpi">
                <div class="ico text-danger"><i class="bi bi-slash-circle"></i></div>
                <div>
                    <div class="t">Không hoạt động</div>
                    <div class="v">@inactive</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card-glass p-3 p-md-4 mb-3">
        @* FIX: đúng tên tham số controller *@
        <form asp-action="Index" method="get" class="pill-filter" id="filterForm">
            <i class="bi bi-search text-muted"></i>
            <input id="qLive" name="searchString" value="@searchString" placeholder="Tìm: tên dịch vụ, mã, địa điểm..." />

            <div class="vr mx-1" style="height:16px;opacity:.25;"></div>

            <i class="bi bi-tags text-muted"></i>
            <select id="loaiSel" name="loai">
                <option value="" selected="@(string.IsNullOrWhiteSpace(loai))">Tất cả loại</option>
                @foreach (var t in loaiList)
                {
                    <option value="@t" selected="@(loai == t)">@t</option>
                }
            </select>

            <div class="vr mx-1" style="height:16px;opacity:.25;"></div>

            <i class="bi bi-activity text-muted"></i>
            <select id="ttSel" name="trangThai">
                <option value="" selected="@(string.IsNullOrWhiteSpace(trangThai))">Tất cả trạng thái</option>
                <option value="Active" selected="@(trangThai == "Active")">Active</option>
                <option value="Inactive" selected="@(trangThai == "Inactive")">Inactive</option>
            </select>

            <button type="submit" class="btn btn-pill btn-confirm ms-auto">
                <i class="bi bi-funnel"></i> Lọc
            </button>

            <a asp-action="Index" class="btn btn-pill btn-grey">
                <i class="bi bi-x-circle"></i> Reset
            </a>
        </form>

        <div class="mt-2 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div class="result-note">
                Hiển thị: <span id="countLive">@total</span> kết quả
            </div>
            <div class="text-muted small">
                Tip: Gõ ở ô tìm kiếm để lọc nhanh tại chỗ (không cần submit).
            </div>
        </div>
    </div>

    <div class="table-wrap shadow-sm">
        <div class="table-responsive">
            <table id="dvTable">
                <thead>
                    <tr>
                        <th>Dịch vụ</th>
                        <th>Loại</th>
                        <th>Địa điểm</th>
                        <th>Đơn giá</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="bi bi-inboxes fs-3 d-block mb-2 opacity-50"></i>
                                Không có dịch vụ nào phù hợp.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            var ok = (item.TrangThai == "Active" || item.TrangThai == "Còn");
                            var dd = item.DiaDiem?.TenDiaDiem ?? "Không gắn địa điểm";

                            // data-* để lọc nhanh realtime
                            var dataSearch = $"{item.TenDichVu} {item.MaDichVu} {dd}".ToLower();
                            var dataLoai = (item.LoaiDichVu ?? "").ToLower();
                            var dataTT = (item.TrangThai ?? "").ToLower();

                            <tr data-search="@dataSearch" data-loai="@dataLoai" data-tt="@dataTT">
                                <td>
                                    <div class="fw-bold">@item.TenDichVu</div>
                                    <div class="text-muted small">
                                        <i class="bi bi-upc"></i>
                                        <span class="font-monospace">@item.MaDichVu</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge-pill badge-type">
                                        <i class="bi bi-tags"></i> @item.LoaiDichVu
                                    </span>
                                </td>
                                <td>@dd</td>
                                <td class="money">@item.DonGia.ToString("N0") đ</td>
                                <td>
                                    <span class="badge-pill @(ok ? "badge-ok" : "badge-bad")">
                                        <i class="bi @(ok ? "bi-check2-circle" : "bi-slash-circle")"></i>
                                        @item.TrangThai
                                    </span>
                                </td>
                                <td class="text-end">
                                    <div class="actions">
                                        <a asp-action="Details" asp-route-id="@item.MaTenDichVu" class="btn-mini">
                                            <i class="bi bi-eye"></i> Xem
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.MaTenDichVu" class="btn-mini">
                                            <i class="bi bi-pencil-square"></i> Sửa
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.MaTenDichVu" class="btn-mini" style="border-color:rgba(239,68,68,.25);color:#dc2626;">
                                            <i class="bi bi-trash"></i> Xóa
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Lọc nhanh realtime tại client (không ảnh hưởng server filter)
        document.addEventListener("DOMContentLoaded", function () {
            const q = document.getElementById("qLive");
            const loai = document.getElementById("loaiSel");
            const tt = document.getElementById("ttSel");
            const table = document.getElementById("dvTable");
            const count = document.getElementById("countLive");
            if (!table) return;

            const rows = Array.from(table.querySelectorAll("tbody tr"));

            function applyLiveFilter() {
                const qv = (q?.value || "").trim().toLowerCase();
                const lv = (loai?.value || "").trim().toLowerCase();
                const tv = (tt?.value || "").trim().toLowerCase();

                let shown = 0;

                rows.forEach(r => {
                    // Nếu là dòng "Không có dữ liệu" thì bỏ qua
                    if (!r.dataset || !r.dataset.search) return;

                    const s = r.dataset.search || "";
                    const rl = r.dataset.loai || "";
                    const rt = r.dataset.tt || "";

                    const okSearch = !qv || s.includes(qv);
                    const okLoai = !lv || rl === lv;
                    const okTT = !tv || rt === tv;

                    const show = okSearch && okLoai && okTT;
                    r.style.display = show ? "" : "none";
                    if (show) shown++;
                });

                if (count) count.textContent = shown.toString();
            }

            // realtime
            q?.addEventListener("input", applyLiveFilter);
            loai?.addEventListener("change", applyLiveFilter);
            tt?.addEventListener("change", applyLiveFilter);

            // chạy lần đầu để đúng số
            applyLiveFilter();
        });
    </script>
}
