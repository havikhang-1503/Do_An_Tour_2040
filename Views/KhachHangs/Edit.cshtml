@model Tour_2040.Models.KhachHang

@{
    ViewData["Title"] = "Chỉnh sửa khách hàng";
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h3 class="fw-bold mb-0">Chỉnh sửa khách hàng</h3>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4 p-lg-5">
            <form asp-action="Edit" asp-route-id="@Model.MaTenKhachHang" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="MaTenKhachHang" />
                <input type="hidden" asp-for="MaKhachHang" />
                <input type="hidden" asp-for="NgayTao" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="MaKhachHang" class="form-label"></label>
                        <input asp-for="MaKhachHang" class="form-control bg-light" readonly />
                    </div>

                    <div class="col-md-8">
                        <label asp-for="HoTen" class="form-label"></label>
                        <input asp-for="HoTen" class="form-control" />
                        <span asp-validation-for="HoTen" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="CCCD" class="form-label"></label>
                        <input asp-for="CCCD" class="form-control" />
                        <span asp-validation-for="CCCD" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="SoDienThoai" class="form-label"></label>
                        <input asp-for="SoDienThoai" class="form-control" />
                        <span asp-validation-for="SoDienThoai" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="col-md-8">
                        <label asp-for="DiaChi" class="form-label"></label>
                        <input asp-for="DiaChi" class="form-control" />
                        <span asp-validation-for="DiaChi" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="NgaySinh" class="form-label"></label>
                        <input asp-for="NgaySinh" type="date" class="form-control" />
                        <span asp-validation-for="NgaySinh" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="NhomKhach" class="form-label"></label>
                        <select asp-for="NhomKhach" class="form-select">
                            <option value="Thường">Thường</option>
                            <option value="Bạc">Bạc</option>
                            <option value="Vàng">Vàng</option>
                            <option value="Kim Cương">Kim Cương</option>
                        </select>
                        <span asp-validation-for="NhomKhach" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="TrangThaiTour" class="form-label"></label>
                        <input asp-for="TrangThaiTour" class="form-control" />
                        <span asp-validation-for="TrangThaiTour" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 d-flex align-items-center">
                        <div class="form-check mt-4">
                            <input asp-for="IsVip" class="form-check-input" />
                            <label asp-for="IsVip" class="form-check-label"></label>
                        </div>
                    </div>

                    <div class="col-12">
                        <label asp-for="GhiChu" class="form-label"></label>
                        <textarea asp-for="GhiChu" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="GhiChu" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mt-4 d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-save"></i> Cập nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
