@model Tour_2040.Models.KhachHang

@{
    ViewData["Title"] = "Xóa khách hàng";
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h3 class="fw-bold mb-0 text-danger">Xóa khách hàng</h3>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4 p-lg-5">
            <p class="mb-3">
                Bạn chắc chắn muốn xóa khách hàng này chứ? Xóa là… xóa thật, không phải “xóa cho vui”.
            </p>

            <div class="border rounded-4 p-3 bg-light">
                <div><b>Mã KH:</b> @Model.MaKhachHang</div>
                <div><b>Họ tên:</b> @Model.HoTen</div>
                <div><b>SĐT:</b> @Model.SoDienThoai</div>
                <div><b>Email:</b> @Model.Email</div>
                <div><b>Nhóm:</b> @Model.NhomKhach</div>
            </div>

            <form asp-action="Delete" method="post" class="mt-4">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="MaTenKhachHang" />

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash"></i> Xóa
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
