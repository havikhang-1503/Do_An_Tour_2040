@*
   Folder: Views/LichTrinhs
   File path: Views/LichTrinhs/AdminDetails.cshtml
   File name: AdminDetails.cshtml
   Label: V-LichTrinh-AdminDetails (A/B/C)
   Mô tả:
   - A: UI glass + pill buttons
   - B: Cập nhật trạng thái rõ ràng
   - C: FIX theo yêu cầu: BỎ khối "Lịch trình chi tiết"
*@

@model Tour_2040.Models.LichTrinh

@{
    ViewData["Title"] = "Chi tiết lịch trình (Admin)";
    var statuses = ViewData["AllowedStatuses"] as string[] ?? Array.Empty<string>();
}

<style>
    :root {
        --bg: #F8F8FF;
        --text: #0f172a;
        --muted: #64748b;
        --border: 1px solid #e2e8f0;
        --shadow: 0 12px 30px rgba(2,6,23,.06);
        --blue: #2563eb;
        --green: #16a34a;
        --yellow: #f59e0b;
        --card: #ffffffee;
    }

    body {
        background: var(--bg) !important;
        color: var(--text);
        font-family: Inter,system-ui;
    }

    .card-glass {
        background: var(--card);
        border: var(--border);
        border-radius: 20px;
        box-shadow: var(--shadow);
        backdrop-filter: blur(10px);
    }

    .btn-pill {
        border-radius: 999px !important;
        font-weight: 900;
        padding: .55rem 1rem;
        box-shadow: 0 10px 18px rgba(2,6,23,.08);
    }

    .btn-confirm {
        background: linear-gradient(135deg,var(--blue),#4f46e5);
        border: none;
        color: #fff;
    }

    .btn-successx {
        background: linear-gradient(135deg,var(--green),#22c55e);
        border: none;
        color: #fff;
    }

    .btn-back {
        background: linear-gradient(135deg,var(--yellow),#fbbf24);
        border: none;
        color: #111827;
    }

    .form-control, .form-select {
        border-radius: 14px;
        padding: .65rem .9rem;
    }

    .form-label {
        font-weight: 900;
        color: #334155;
        font-size: .88rem;
    }

    .sub {
        color: var(--muted);
        font-size: .92rem;
    }

    .kv {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding: .45rem 0;
        border-bottom: 1px dashed #e5e7eb;
    }

        .kv:last-child {
            border-bottom: none;
        }

    .k {
        color: var(--muted);
        font-weight: 800;
    }

    .v {
        font-weight: 900;
    }

    .mono {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    }
</style>

<div class="container-fluid py-4 px-lg-5 animate__animated animate__fadeIn">

    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-3">
        <div>
            <div class="text-muted small mb-1"><i class="bi bi-shield-check"></i> Lịch trình / <b class="text-dark">Chi tiết (Admin)</b></div>
            <h3 class="fw-bold mb-1">Chi tiết lịch trình</h3>
            <div class="sub">Mã: <span class="mono fw-bold">@Model.MaLichTrinh</span></div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-pill btn-back" asp-action="AdminIndex">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-4">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-4">@TempData["Error"]</div>
    }

    <div class="row g-3">
        <div class="col-lg-6">
            <div class="card-glass p-3 p-md-4">
                <div class="fw-bold mb-2"><i class="bi bi-info-circle"></i> Thông tin</div>

                <div class="kv"><div class="k">Tour</div><div class="v text-end">@(Model.Tour?.TenTour ?? Model.TourId)</div></div>
                <div class="kv"><div class="k">Khách</div><div class="v text-end">@(Model.User?.UserName ?? Model.User?.Email ?? Model.UserId)</div></div>
                <div class="kv"><div class="k">Ngày đặt</div><div class="v text-end">@Model.NgayDat.ToString("dd/MM/yyyy HH:mm")</div></div>
                <div class="kv"><div class="k">Số người</div><div class="v text-end">@(Model.SoNguoiLon + Model.SoTreEm)</div></div>
                <div class="kv"><div class="k">Tổng tiền</div><div class="v text-end">@Model.TongTien.ToString("N0")</div></div>
                <div class="kv"><div class="k">Trạng thái</div><div class="v text-end">@Model.TrangThai</div></div>

                @if (!string.IsNullOrWhiteSpace(Model.GhiChuTrangThai))
                {
                    <div class="mt-3 p-3 rounded-4" style="background:#f1f5f9;">
                        <div class="fw-bold mb-1">Ghi chú hiện tại</div>
                        <div class="text-muted">@Model.GhiChuTrangThai</div>
                    </div>
                }

                @if (Model.TrangThai == "Đã hủy")
                {
                    <div class="mt-3 p-3 rounded-4" style="background:#fef2f2;">
                        <div class="fw-bold mb-1">Thông tin hủy</div>
                        <div class="text-muted">Ngày hủy: @(Model.NgayHuy?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
                        <div class="text-muted">Lý do: @(Model.LyDoHuy ?? "-")</div>
                    </div>
                }
            </div>

            <div class="card-glass p-3 p-md-4 mt-3">
                <div class="fw-bold mb-2"><i class="bi bi-pencil-square"></i> Cập nhật trạng thái</div>

                <form asp-action="UpdateStatus" method="post">
                    <input type="hidden" name="id" value="@Model.MaLichTrinh" />

                    <div class="mb-2">
                        <label class="form-label">Trạng thái</label>
                        <select class="form-select" name="status" required>
                            @foreach (var s in statuses)
                            {
                                <option value="@s" selected="@(s == (Model.TrangThai ?? ""))">@s</option>
                            }
                        </select>
                    </div>

                    <div class="mb-2">
                        <label class="form-label">Ghi chú</label>
                        <textarea class="form-control" name="note" rows="3" placeholder="Ghi chú cho khách / nội bộ..."></textarea>
                    </div>

                    <button class="btn btn-pill btn-successx" type="submit">
                        <i class="bi bi-check2-circle"></i> Lưu cập nhật
                    </button>
                </form>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card-glass p-3 p-md-4">
                <div class="fw-bold mb-2"><i class="bi bi-eye-slash"></i> Lịch trình chi tiết</div>
                <div class="text-muted">
                    Phần “Lịch trình chi tiết” đã được ẩn theo yêu cầu để admin chỉ quản lý đơn đặt và trạng thái.
                </div>
            </div>
        </div>
    </div>
</div>
