@model IEnumerable<Tour_2040.Models.XaPhuong>

@{
    ViewData["Title"] = "Quản lý Xã/Phường";
    var currentKeyword = ViewData["CurrentKeyword"] as string ?? "";
    var currentTinh = ViewBag.CurrentTinhId as int?; // ID tỉnh đang lọc
    var total = Model.Count();
}

<style>
    /* CSS giống hệt file TinhThanhs/Index.cshtml */
    :root {
        --primary: #4f46e5;
    }

    body {
        background-color: #f8f9fa;
    }

    .glass-bar {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
    }

    .kpi-card {
        background: white;
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,0.03);
        transition: transform 0.3s ease;
    }

        .kpi-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        }

    .table-elegant thead th {
        font-size: 0.75rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #6b7280;
        font-weight: 600;
        padding: 1rem;
        border-bottom: 2px solid #f3f4f6;
    }

    .table-elegant tbody td {
        padding: 1rem;
        vertical-align: middle;
        color: #374151;
        font-weight: 500;
    }

    .icon-box {
        width: 45px;
        height: 45px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
    }
</style>

<div class="container-fluid py-4 px-4 animate__animated animate__fadeIn">

    <div class="card glass-bar rounded-4 mb-4 p-3 sticky-top" style="top: 10px; z-index: 99;">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="bg-info text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 48px; height: 48px;">
                    <i class="bi bi-diagram-3-fill fs-5"></i>
                </div>
                <div>
                    <h4 class="fw-bold text-dark mb-0">Xã / Phường</h4>
                    <small class="text-muted">Danh mục hành chính cấp 2</small>
                </div>
            </div>

            <form asp-action="Index" method="get" class="d-flex gap-2 flex-wrap">
                <div class="input-group input-group-sm rounded-pill border bg-white" style="width: 250px;">
                    <span class="input-group-text bg-white border-0 ps-3 text-muted"><i class="bi bi-search"></i></span>
                    <input type="text" name="keyword" class="form-control border-0 shadow-none"
                           placeholder="Nhập tên xã/phường..." value="@currentKeyword">
                </div>

                <select name="tinhThanhId" class="form-select form-select-sm rounded-pill border bg-white shadow-none" style="width: 200px;" onchange="this.form.submit()">
                    <option value="">-- Tất cả Tỉnh/Thành --</option>
                    @if (ViewBag.TinhThanhId != null)
                    {
                        foreach (var item in (IEnumerable<SelectListItem>)ViewBag.TinhThanhId)
                        {
                            /* Logic check selected thủ công nếu viewbag trả về SelectListItems */
                            if (item.Value == currentTinh?.ToString())
                            {
                                <option value="@item.Value" selected>📍 @item.Text</option>
                            }
                            else
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        }
                    }
                </select>

                <div class="vr mx-1 text-muted h-50 align-self-center"></div>

                <a asp-action="Create" asp-route-tinhThanhId="@currentTinh" class="btn btn-dark btn-sm rounded-pill px-3 fw-medium shadow-sm d-flex align-items-center gap-2">
                    <i class="bi bi-plus-lg"></i> Thêm Xã
                </a>
            </form>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="kpi-card p-3 d-flex align-items-center gap-3">
                <div class="icon-box bg-info bg-opacity-10 text-info"><i class="bi bi-layers-fill"></i></div>
                <div>
                    <h4 class="fw-bold mb-0">@total</h4>
                    <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">
                        @(currentTinh != null ? "Xã thuộc tỉnh đã chọn" : "Tổng số xã/phường")
                    </small>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover table-elegant mb-0 w-100">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Mã Xã/Phường</th>
                        <th>Tên Xã/Phường</th>
                        <th>Trực thuộc Tỉnh</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <div class="mb-3"><i class="bi bi-filter-circle display-4 text-muted opacity-25"></i></div>
                                <p class="text-muted fw-medium mb-0">Không tìm thấy dữ liệu phù hợp.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="icon-box bg-light text-info border">
                                            <i class="bi bi-geo-alt"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark font-monospace">@item.MaXaPhuong</div>
                                            <div class="small text-muted">Mã HC</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="fw-medium text-dark">@item.TenXaPhuong</span>
                                </td>
                                <td>
                                    @if (item.TinhThanh != null)
                                    {
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle px-3 py-2 rounded-pill">
                                                <i class="bi bi-building-fill me-1"></i> @item.TinhThanh.TenTinh
                                            </span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">---</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a asp-action="Edit" asp-route-id="@item.MaXaPhuong" class="btn btn-light btn-sm text-primary rounded-start" title="Sửa">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.MaXaPhuong" class="btn btn-light btn-sm text-danger rounded-end" title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>