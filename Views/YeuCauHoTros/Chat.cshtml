@*
Folder: Views/YeuCauHoTro
FilePath: Views/YeuCauHoTro/Chat.cshtml  (hoặc file ChiTiet/Chat của em)
FileName: Chat.cshtml
Method/Class/View: YeuCauHoTro - Chat/ChiTiet
Label: A,B,C
Desc:
A) Tách UI Admin/Staff và User (Admin flat, User voucher/glass)
B) Lề ngoài ổn định khi zoom (page-shell + outer-gutter clamp), toolbar gọn
C) Giữ nguyên chức năng gửi tin nhắn + auto scroll cuối
*@

@model Tour_2040.Models.YeuCauHoTro
@{
    ViewData["Title"] = "Chi tiết hỗ trợ";
    var messages = ViewBag.Messages as List<Tour_2040.Models.TinNhanHoTro>;
    bool isStaff = User.IsInRole("Admin") || User.IsInRole("Staff");

    // Badge status mapping
    string st = (Model.TrangThai ?? "").Trim();
    string statusKey = st == "Đã phản hồi" ? "done"
                    : st == "Đang xử lý" ? "processing"
                    : st == "Chờ xử lý" ? "pending"
                    : "other";
}

<style>
    :root {
        --bg-system: #F7F8FF;
        --card-bg: rgba(255,255,255,0.86);
        --glass-border: 1px solid rgba(148,163,184,0.35);
        --shadow-soft: 0 10px 30px rgba(2, 6, 23, 0.08);
        --text-main: #0f172a;
        --text-muted: #64748b;
        --border-thin: 1px solid rgba(226,232,240,0.9);
        --primary-blue: #3a86ff; /* confirm */
        --success-green: #22c55e; /* success */
        --danger-red: #ef4444; /* danger */
        --warning-yellow: #f59e0b; /* back */

        --outer-gutter: clamp(16px, 4vw, 72px);
        --radius-lg: 20px;
        --radius-md: 14px;
    }

    body {
        background: radial-gradient(1200px 500px at 20% 0%, rgba(58,134,255,0.10), transparent 60%), radial-gradient(900px 420px at 90% 10%, rgba(34,197,94,0.08), transparent 55%), radial-gradient(900px 420px at 70% 100%, rgba(245,158,11,0.10), transparent 55%), var(--bg-system) !important;
        font-family: Inter,system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
        color: var(--text-main);
    }

    /* ===== Layout giữ lề ổn định khi zoom ===== */
    .page-shell {
        width: 100%;
        padding: 12px var(--outer-gutter);
        box-sizing: border-box;
    }

    .page-wrap {
        max-width: 1180px;
        margin: 0 auto;
    }

    /* ===== Buttons pill ===== */
    .btn-pill {
        border-radius: 999px !important;
        padding: 10px 14px;
        font-weight: 900;
        font-size: 0.85rem;
        border: 1px solid transparent;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none !important;
        transition: transform .15s ease, box-shadow .15s ease, background .15s ease, border-color .15s ease;
        user-select: none;
        white-space: nowrap;
    }

        .btn-pill:active {
            transform: translateY(1px);
        }

    .btn-pill-primary {
        background: rgba(58,134,255,0.12);
        border-color: rgba(58,134,255,0.35);
        color: #0b2a66 !important;
    }

        .btn-pill-primary:hover {
            background: rgba(58,134,255,0.18);
            box-shadow: 0 10px 18px rgba(58,134,255,0.14);
        }

    .btn-pill-warning {
        background: rgba(245,158,11,0.14);
        border-color: rgba(245,158,11,0.35);
        color: #5a3a07 !important;
    }

        .btn-pill-warning:hover {
            background: rgba(245,158,11,0.20);
            box-shadow: 0 10px 18px rgba(245,158,11,0.12);
        }

    .btn-pill-neutral {
        background: rgba(100,116,139,0.10);
        border-color: rgba(100,116,139,0.25);
        color: var(--text-main) !important;
    }

        .btn-pill-neutral:hover {
            background: rgba(100,116,139,0.14);
        }

    /* ===== Status badge ===== */
    .status-badge {
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 900;
        border: 1px solid transparent;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        white-space: nowrap;
        text-transform: uppercase;
        letter-spacing: 0.4px;
    }

        .status-badge .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
        }

    .st-pending {
        background: rgba(245,158,11,0.12);
        border-color: rgba(245,158,11,0.30);
        color: #5a3a07;
    }

        .st-pending .dot {
            background: rgba(245,158,11,0.95);
        }

    .st-processing {
        background: rgba(58,134,255,0.12);
        border-color: rgba(58,134,255,0.30);
        color: #0b2a66;
    }

        .st-processing .dot {
            background: rgba(58,134,255,0.9);
        }

    .st-done {
        background: rgba(34,197,94,0.10);
        border-color: rgba(34,197,94,0.30);
        color: #14532d;
    }

        .st-done .dot {
            background: rgba(34,197,94,0.9);
        }

    .st-other {
        background: rgba(239,68,68,0.10);
        border-color: rgba(239,68,68,0.30);
        color: #7f1d1d;
    }

        .st-other .dot {
            background: rgba(239,68,68,0.9);
        }

    /* ===== Header: Admin vs User ===== */
    .header-admin {
        background: rgba(255,255,255,0.92);
        border: var(--border-thin);
        border-radius: 18px;
        padding: 16px 16px;
        box-shadow: 0 10px 26px rgba(2,6,23,0.06);
    }

    .header-user {
        background: var(--card-bg);
        border: var(--glass-border);
        border-radius: 18px;
        padding: 16px 16px;
        box-shadow: var(--shadow-soft);
        backdrop-filter: blur(10px);
    }

    .hero {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .hero-icon {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        border: var(--glass-border);
        background: rgba(58,134,255,0.10);
        color: var(--primary-blue);
        font-size: 1.15rem;
    }

        .hero-icon.admin {
            border: var(--border-thin);
            background: rgba(245,158,11,0.10);
            color: var(--warning-yellow);
        }

    .sub {
        margin: 2px 0 0 0;
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    /* ===== Chat card ===== */
    .chat-card {
        margin-top: 12px;
        border-radius: var(--radius-lg);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        height: 74vh;
    }

        .chat-card.admin {
            background: #fff;
            border: var(--border-thin);
            box-shadow: 0 10px 26px rgba(2,6,23,0.06);
        }

        .chat-card.user {
            background: var(--card-bg);
            border: var(--glass-border);
            box-shadow: var(--shadow-soft);
            backdrop-filter: blur(10px);
        }

    .chat-box {
        flex: 1;
        overflow-y: auto;
        padding: 18px;
        background: rgba(252,252,253,0.9);
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

        .chat-box::-webkit-scrollbar {
            width: 6px;
        }

        .chat-box::-webkit-scrollbar-thumb {
            background: rgba(148,163,184,0.35);
            border-radius: 10px;
        }

    /* Message bubble */
    .msg-group {
        max-width: 78%;
        display: flex;
        flex-direction: column;
    }

    .msg-left {
        align-self: flex-start;
    }

    .msg-right {
        align-self: flex-end;
    }

    .msg-meta {
        font-size: 0.72rem;
        font-weight: 900;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 4px;
        letter-spacing: 0.5px;
    }

    .msg-right .msg-meta {
        text-align: right;
    }

    .bubble {
        padding: 12px 16px;
        font-size: 0.95rem;
        line-height: 1.5;
        position: relative;
        border-radius: 18px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        word-break: break-word;
    }

    /* Left bubble */
    .msg-left .bubble {
        background: #fff;
        border: var(--border-thin);
        color: var(--text-main);
        border-radius: 18px 18px 18px 6px;
    }

    /* Right bubble (my message) */
    .msg-right .bubble {
        background: rgba(58,134,255,0.95);
        color: #fff;
        border-radius: 18px 18px 6px 18px;
    }

    /* time */
    .msg-time {
        font-size: 0.68rem;
        opacity: 0.85;
        margin-top: 6px;
        color: var(--text-muted);
    }

    .msg-right .msg-time {
        color: rgba(255,255,255,0.85);
        text-align: right;
    }

    /* staff tag */
    .staff-tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 2px 8px;
        border-radius: 999px;
        font-size: 0.62rem;
        font-weight: 900;
        background: rgba(58,134,255,0.12);
        border: 1px solid rgba(58,134,255,0.25);
        color: #0b2a66;
        vertical-align: middle;
        margin-left: 6px;
    }

    /* Footer input */
    .chat-footer {
        padding: 14px 16px;
        background: rgba(255,255,255,0.96);
        border-top: var(--border-thin);
    }

    .input-pill {
        border-radius: 999px !important;
        border: 1px solid rgba(226,232,240,1);
        padding: 10px 18px;
        background: rgba(248,250,252,0.95);
        font-size: 0.92rem;
        transition: all .2s;
    }

        .input-pill:focus {
            background: #fff;
            border-color: rgba(58,134,255,0.55);
            box-shadow: 0 0 0 4px rgba(58, 134, 255, 0.10);
            outline: none;
        }

    .btn-send {
        width: 46px;
        height: 46px;
        border-radius: 999px;
        background: rgba(58,134,255,0.95);
        color: #fff;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform .15s ease, background .15s ease;
        box-shadow: 0 10px 18px rgba(58,134,255,0.22);
    }

        .btn-send:hover {
            transform: scale(1.03);
            background: #2563eb;
        }

    /* empty state */
    .empty {
        padding: 52px 18px;
        text-align: center;
        color: var(--text-muted);
        opacity: 0.95;
    }

        .empty i {
            font-size: 2.6rem;
            opacity: 0.25;
            display: block;
            margin-bottom: 10px;
        }

    @@keyframes shake {
        0%, 100% {
            transform: translateX(0);
        }

        25% {
            transform: translateX(-5px);
        }

        75% {
            transform: translateX(5px);
        }
    }

    .shake-error {
        animation: shake 0.3s ease-in-out;
    }

    @@media (max-width: 768px) {
        .chat-card {
            height: 72vh;
        }

        .msg-group {
            max-width: 92%;
        }
    }
</style>

<div class="page-shell">
    <div class="page-wrap animate__animated animate__fadeIn">

        @* ===== HEADER ===== *@
        <div class="@(isStaff ? "header-admin" : "header-user")">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                <div>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-1" style="font-size: 0.75rem;">
                            <li class="breadcrumb-item">
                                <a asp-action="Index" class="text-decoration-none">Hỗ trợ</a>
                            </li>
                            <li class="breadcrumb-item active">Chi tiết phiếu</li>
                        </ol>
                    </nav>

                    <div class="hero">
                        <div class="hero-icon @(isStaff ? "admin" : "")">
                            <i class="bi @(isStaff ? "bi-headset" : "bi-chat-square-dots")"></i>
                        </div>
                        <div>
                            <div class="d-flex flex-wrap align-items-center gap-2">
                                <h4 class="fw-bold mb-0">@Model.ChuDe</h4>
                                <span class="font-monospace text-primary fw-bold">#@Model.MaYeuCauHoTro</span>
                            </div>
                            <div class="sub">
                                @(isStaff ? "Kênh hỗ trợ dành cho nhân viên xử lý yêu cầu." : "Theo dõi phản hồi và gửi thêm nội dung khi cần.")
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <span class="status-badge @(statusKey == "done" ? "st-done" : statusKey == "processing" ? "st-processing" : statusKey == "pending" ? "st-pending" : "st-other")">
                        <span class="dot"></span> @Model.TrangThai
                    </span>

                    <a asp-action="Index" class="btn-pill btn-pill-warning">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                </div>
            </div>
        </div>

        @* ===== CHAT CARD ===== *@
        <div class="chat-card @(isStaff ? "admin" : "user")">
            <div class="chat-box" id="scrollArea">
                @if (messages != null && messages.Any())
                {
                    foreach (var msg in messages)
                    {
                        // isMe logic giữ nguyên như file cũ
                        bool isMe = (isStaff && msg.LaNhanVien) || (!isStaff && !msg.LaNhanVien);

                        <div class="msg-group @(isMe ? "msg-right" : "msg-left") animate__animated animate__fadeInUp animate__faster">
                            <div class="msg-meta">
                                @msg.NguoiGui
                                @if (msg.LaNhanVien)
                                {
                                    <span class="staff-tag">
                                        <i class="bi bi-patch-check-fill"></i> NV ROYAL
                                    </span>
                                }
                            </div>
                            <div class="bubble">
                                @msg.NoiDung
                                <div class="msg-time">@msg.ThoiGian.ToString("HH:mm")</div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty">
                        <i class="bi bi-chat-dots"></i>
                        <div class="fw-bold" style="color: var(--text-main);">Bắt đầu cuộc hội thoại để được hỗ trợ</div>
                        <div class="small">Gửi tin nhắn bên dưới, hệ thống sẽ ghi nhận ngay.</div>
                    </div>
                }
            </div>

            @* ===== FOOTER INPUT ===== *@
            <div class="chat-footer">
                <form asp-action="SendMessage" method="post" class="d-flex align-items-center gap-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.MaYeuCauHoTro" />

                    <div class="flex-grow-1">
                        <input type="text" name="messageContent"
                               class="form-control input-pill"
                               placeholder="@(isStaff ? "Nhập phản hồi cho khách hàng..." : "Nhập tin nhắn của bạn...")"
                               autocomplete="off" required />
                    </div>

                    <button type="submit" class="btn-send" title="Gửi">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>

<script>
    (function () {
        function scrollToBottom() {
            var box = document.getElementById("scrollArea");
            if (!box) return;
            box.scrollTop = box.scrollHeight;
        }

        document.addEventListener("DOMContentLoaded", scrollToBottom);
        window.addEventListener("load", scrollToBottom);
    })();
</script>
